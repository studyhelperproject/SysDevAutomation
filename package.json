{
  "name": "app",
  "version": "1.0.0",
  "description": "「人の介入を最小限にし、機械的に要件を詰める」ための、AIによる要定義・プロジェクト管理自動化システムです。",
  "type": "module",
  "main": "src/index.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' npx ts-node src/index.ts",
    "test": "npm run test:slack && npm run test:github && npm run test:feedback && npm run test:sp && npm run test:context",
    "test:slack": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' npx ts-node tests/test_slack_integration.ts",
    "test:github": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' npx ts-node tests/test_github_client.ts",
    "test:feedback": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' npx ts-node tests/test_slack_feedback.ts",
    "test:sp": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' npx ts-node tests/test_sp_aggregation.ts",
    "test:context": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' npx ts-node tests/test_context_management.ts",
    "aggregate-sp": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' npx ts-node src/aggregate_sp.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/studyhelperproject/SysDevAutomation.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/studyhelperproject/SysDevAutomation/issues"
  },
  "homepage": "https://github.com/studyhelperproject/SysDevAutomation#readme",
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "@google/generative-ai": "^0.24.1",
    "@slack/bolt": "^4.6.0",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.1",
    "octokit": "^5.0.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
